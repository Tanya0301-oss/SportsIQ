# ════════════════════════════════════════════════════════════════════════════
# Sports Analytics Platform - Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════════════════

# ─── Application Settings ─────────────────────────────────────────────────────
APP_NAME="Sports Analytics Platform"
DEBUG=True

# ─── Database ─────────────────────────────────────────────────────────────────
# For development: sqlite+aiosqlite:///./sports.db
# For production: postgresql+asyncpg://user:password@localhost:5432/sports_db
DATABASE_URL="sqlite+aiosqlite:///./sports.db"

# ─── Redis (Optional) ─────────────────────────────────────────────────────────
# Leave empty to use in-memory pub/sub (development)
# For production: redis://localhost:6379/0
REDIS_URL=""

# ─── Data Source Configuration ─────────────────────────────────────────────────
# Options: "live" (real football-data.org API) or "simulator" (demo synthetic data)
DATA_SOURCE="live"

# ─── Football-Data.org API ────────────────────────────────────────────────────
# REQUIRED for live data mode
# Get your FREE API key from: https://www.football-data.org/
# Free tier: 10 requests/min, includes live matches, seasons dating back
FOOTBALL_DATA_API_KEY="YOUR_FREE_API_KEY_HERE"

# Base URL for the API (don't change unless API moves)
FOOTBALL_DATA_BASE_URL="https://api.football-data.org/v4"

# ─── Active Leagues (for live data) ────────────────────────────────────────────
# Comma-separated list of league codes from football-data.org
# Common leagues:
#   PL   = Premier League (England)
#   SA   = Serie A (Italy)
#   DL   = Bundesliga (Germany)
#   FL1  = Ligue 1 (France)
#   PPL  = Primeira Liga (Portugal)
#   EC   = European Championship
#   CL   = Champions League
ACTIVE_LEAGUES="PL,SA,DL,FL1,PPL"

# ─── Polling Intervals ─────────────────────────────────────────────────────────
# How often to check for new match events (seconds)
LIVE_FEED_POLL_SECONDS=30

# How often simulator emits events (seconds) - only for demo mode
SIMULATOR_TICK_SECONDS=10

# ─── Artifacts & ML ───────────────────────────────────────────────────────────
ARTIFACTS_DIR="ml/artifacts"

# ─── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173"

# ─── Monitoring ───────────────────────────────────────────────────────────────
ENABLE_METRICS=True
